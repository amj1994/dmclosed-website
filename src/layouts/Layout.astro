---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "DMClosed — A done-for-you AI sales agent for your business",
  description = "DMClosed deploys and operates an AI sales agent across WhatsApp, Instagram, SMS and more. It replies in seconds, handles objections, follows up for days, and books calls onto your calendar — 24/7. Managed for you from $497/mo. Book a demo.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="DMClosed" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#0A0503" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- preload hero poster + video for instant LCP -->
    <link rel="preload" as="image" href="/media/robot-hero-poster.jpg" />

    <!-- JSON-LD: SaaS product -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "DMClosed",
      "applicationCategory": "BusinessApplication",
      "description": description,
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "497", "priceCurrency": "USD", "description": "Managed AI sales agent — from $497/mo" }
    })} />

    <script is:inline>
      // Mark motion-capable before paint so reveals only hide when we can animate them.
      (function () {
        var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (!reduce) document.documentElement.classList.add("has-motion");
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
    <style>
      .skip-link {
        position: absolute; left: 1rem; top: -3rem;
        background: var(--primary); color: var(--on-primary);
        padding: 0.6rem 1rem; border-radius: 8px; z-index: var(--z-toast);
        transition: top var(--dur-fast) var(--ease-out-quart);
      }
      .skip-link:focus { top: 1rem; }
    </style>

    <!-- Lunacal element-click embed code begins -->
    <script type="text/javascript" is:inline>
      (function(L,U,N){let p=(a,ar)=>a.q.push(ar),d=L.document;L.Lunacal=L.Lunacal||function(){let lun=L.Lunacal,ar=arguments;if(!lun.loaded){lun.ns={};lun.q=lun.q||[];d.head.appendChild(d.createElement("script")).src=U;lun.loaded=!0}if(ar[0]===N){const api=function(){p(api,arguments)};const ns=ar[1];api.q=api.q||[];if(typeof ns==="string"){lun.ns[ns]=lun.ns[ns]||api;p(lun.ns[ns],ar);p(lun,["initNamespace",ns])}else p(lun,ar);return}p(lun,ar)};if(!L.Cal)L.Cal=L.Lunacal})(window,"https://app.lunacal.ai/embed/embed.js","init");Lunacal("init","1-1-consultation",{origin:"https://app.lunacal.ai"});
      // Enable auto-forwarding of query parameters
      Lunacal.config = Lunacal.config || {};
      Lunacal.config.forwardQueryParams = true;

      Lunacal.ns["1-1-consultation"]("preload", { calLink: "amj/1-1-consultation", type: "modal", options: { prerenderIframe: false } });
      Lunacal.ns["1-1-consultation"]("ui", {"theme":"dark","styles":{"branding":{}},"hideEventTypeDetails":false,"layout":"","cssVarsPerTheme":{"light":{"theme-border":"#DFDFDF","theme-background-primary":"#ff6d00","theme-background-secondary":"#EDEDED","theme-background-card":"#FFFFFF","theme-background-base":"#FFFFFF","theme-text-primary":"#FFFFFF","theme-text-secondary":"#000000","theme-text-card":"#ffd2a7","theme-text-base":"#0B0D0E","theme-rounded-base":"20px","theme-rounded-calendar":"24px","theme-rounded-timeslot":"12px","theme-rounded-day":"6px","theme-rounded-button":"6px","theme-shadow-calendar":"2px 2px 4px 0px #0000001A","theme-shadow-button":"2px 2px 2px 0px #0000001A","theme-shadow-timeslot":"0px 0px 0px 0px #000000","theme-font-family":"Outfit"},"dark":{"theme-border":"#202020","theme-background-primary":"#ff6d00","theme-background-secondary":"#333333","theme-background-card":"#090909","theme-background-base":"#000000","theme-text-primary":"#000000","theme-text-secondary":"#FFFFFF","theme-text-card":"#ffd2a7","theme-text-base":"#FFFFFF","theme-rounded-base":"20px","theme-rounded-calendar":" 24px","theme-rounded-timeslot":"12px","theme-rounded-day":"6px","theme-rounded-button":"6px","theme-shadow-calendar":"2px 2px 4px 0px #0000001A","theme-shadow-button":"2px 2px 2px 0px #0000001A","theme-shadow-timeslot":"0px 0px 0px 0px #000000","theme-font-family":"Outfit"}},"displayedContent":{"image":true,"name":true,"designation":true,"description":true,"eventName":true,"highlightBar":false},"background":{"type":"animated","presetId":"light-rays"},"stylePreset":null});

      // Wire every "Book a demo" CTA to open the calendar modal on click.
      (function () {
        var wire = function () {
          document.querySelectorAll('a, button').forEach(function (el) {
            if (el.hasAttribute('data-cal-link')) return;
            if (/book a demo/i.test((el.textContent || '').trim())) {
              el.setAttribute('data-cal-link', 'amj/1-1-consultation');
              el.setAttribute('data-cal-namespace', '1-1-consultation');
              el.setAttribute('data-cal-config', '{"layout":""}');
              // stop the anchor from jumping to #pricing — only open the calendar
              el.addEventListener('click', function (e) { e.preventDefault(); });
            }
          });
        };
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', wire);
        else wire();
      })();
    </script>
    <!-- Lunacal element-click embed code ends -->
  </body>
</html>
