---
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---
<footer class="footer">
  <!-- robot render peeks over the bar; rises in on scroll; eyes blink -->
  <span class="footer-robot">
    <span class="footer-riser" data-footer-riser>
      <img class="footer-img" src="/media/footer-robot.jpg" alt="DMClosed robot" width="1000" height="667" decoding="async" loading="lazy" />
      <span class="fblink fblink-l" aria-hidden="true"></span>
      <span class="fblink fblink-r" aria-hidden="true"></span>
    </span>
  </span>

  <div class="footer-bar">
    <div class="container footer-bar-inner">
      <div class="fb-brand">
        <Logo />
        <p class="fb-line">AI sales agent.<br />Done-for-you. Live in days.</p>
      </div>
      <p class="fb-pitch">
        Let's put a closer<br /><span class="text-primary">in your inbox.</span>
      </p>
      <a href="#pricing" class="btn btn-primary btn-arrow fb-btn" data-magnetic>
        Book a demo
        <svg viewBox="0 0 24 24" width="16" height="16"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>

  <div class="container footer-legal">
    <span>© {year} DMClosed. All rights reserved.</span>
    <nav aria-label="Footer">
      <a href="#how">How it works</a>
      <a href="#pricing">Pricing</a>
      <a href="#">Privacy</a>
      <a href="#">Terms</a>
    </nav>
  </div>
</footer>

<style>
  .footer { background: var(--bg-deep); position: relative; padding-top: 13.5rem; }

  .footer-robot {
    position: absolute; left: 50%; top: -1.5rem; z-index: 2;
    width: min(430px, 92vw);
    transform: translateX(-50%);
    pointer-events: none;
  }
  .footer-riser { position: relative; display: block; width: 100%; }
  .footer-img {
    display: block; width: 100%; height: auto;
    /* fade the render's rectangular edges so it melts into the dark footer */
    -webkit-mask-image: radial-gradient(68% 74% at 50% 44%, #000 46%, transparent 88%);
    mask-image: radial-gradient(68% 74% at 50% 44%, #000 46%, transparent 88%);
  }
  html.has-motion .footer-riser { opacity: 0; transform: translateY(90px); }

  /* eyelids over the glowing eyes — flick on briefly so the robot blinks */
  .fblink {
    position: absolute; width: 6.4%; height: 13.5%; border-radius: 50%;
    transform: translate(-50%, -50%); opacity: 0;
    background: radial-gradient(circle at 50% 36%, #2a160c, #0d0704 72%);
  }
  .fblink-l { left: 40%; top: 31.5%; }
  .fblink-r { left: 59.6%; top: 31.5%; }
  html.has-motion .fblink { animation: fblink 4.6s infinite; }
  @keyframes fblink { 0%, 91%, 100% { opacity: 0; } 94%, 96.5% { opacity: 1; } }

  .footer-bar {
    position: relative; z-index: 1;
    background:
      radial-gradient(70% 150% at 50% 0%, oklch(0.585 0.215 33 / 0.22), transparent 70%),
      linear-gradient(180deg, var(--surface), var(--bg-deep));
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line-soft);
  }
  .footer-bar-inner {
    display: flex; align-items: center; justify-content: space-between; gap: clamp(1.5rem, 1rem + 3vw, 4rem);
    padding-top: 3.4rem; padding-bottom: clamp(2rem, 1.4rem + 2vw, 3rem);
  }
  .fb-brand { display: grid; gap: 0.7rem; flex-shrink: 0; }
  .fb-line { color: var(--ink-2); font-size: 0.95rem; line-height: 1.35; }
  .fb-pitch { font-family: var(--font-display); font-weight: 800; font-size: clamp(1.5rem, 1.1rem + 1.8vw, 2.4rem); line-height: 1.05; letter-spacing: -0.02em; text-align: center; }
  .fb-btn { flex-shrink: 0; }

  .footer-legal {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding-block: 1.4rem; flex-wrap: wrap;
  }
  .footer-legal span { color: var(--muted); font-size: 0.85rem; }
  .footer-legal nav { display: flex; gap: 1.4rem; flex-wrap: wrap; }
  .footer-legal a { color: var(--ink-2); font-size: 0.88rem; transition: color var(--dur-fast); }
  .footer-legal a:hover { color: var(--primary-hi); }

  @media (max-width: 860px) {
    .footer { padding-top: 10rem; }
    .footer-bar-inner { flex-direction: column; text-align: center; gap: 1.2rem; }
    .fb-brand { justify-items: center; }
    .footer-robot { width: min(380px, 90vw); }
    .footer-legal { flex-direction: column; text-align: center; }
  }
  @media (prefers-reduced-motion: reduce) {
    html.has-motion .footer-riser { opacity: 1; transform: none; }
  }
</style>
