---
interface Props { compact?: boolean }
const { compact = false } = Astro.props;
---
<a href="/" class={`logo ${compact ? "is-compact" : ""}`} aria-label="DMClosed home">
  <img src="/logo.png" alt="DMClosed" width="1307" height="402" decoding="async" />
</a>
<style>
  .logo { display: inline-flex; align-items: center; }
  .logo img {
    height: 46px; width: auto;
    /* tint the legacy blue mark into the molten-orange brand */
    filter: hue-rotate(168deg) saturate(1.35) brightness(1.05)
            drop-shadow(0 4px 16px var(--glow-ember));
  }
  .logo.is-compact img { height: 40px; }
  @media (max-width: 520px) {
    .logo img { height: 38px; }
  }
</style>
