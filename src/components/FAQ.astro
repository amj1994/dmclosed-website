---
const faqs = [
  { q: "Will it sound like a robot to our leads?", a: "No. DMClosed replies in natural, human phrasing, breaks messages into chunks instead of walls of text, and adapts its tone to your brand. Most leads never realize they're talking to an AI." },
  { q: "Is this a tool we have to learn and run?", a: "No — it's done-for-you. We build the agent, train it on your offer and objections, connect your channels and calendar, and tune it every week. Your team just takes the calls it books." },
  { q: "How does the demo work?", a: "We walk through your current DM flow, show DMClosed handling real objection-heavy conversations, and map exactly which channels and offers we'd deploy on. About 20 minutes, no obligation." },
  { q: "Can it really close high-ticket deals?", a: "Yes. It has handled objection-heavy conversations on services up to $40,000+, holding price and following up for weeks without a human stepping in. Proven at $50K+ deal sizes." },
  { q: "Do we keep control of the conversations?", a: "Always. You can read every thread, jump in any time, and set rules for when the agent should hand a conversation to your team. It works for you, not around you." },
  { q: "Which channels does it cover?", a: "WhatsApp, Instagram (DMs + comments), Messenger, Telegram, SMS, iMessage, email, and web chat — all from one shared brain with memory across every channel." },
];
---
<section class="faq section" aria-labelledby="faq-h">
  <div class="container-narrow">
    <header class="faq-head">
      <p class="kicker reveal">Before you ask</p>
      <h2 id="faq-h" class="reveal">The questions every operator has.</h2>
    </header>
    <div class="faq-list">
      {faqs.map((f, i) => (
        <details class="faq-item reveal" name="faq" {...(i === 0 ? { open: true } : {})}>
          <summary>
            <span class="faq-q">{f.q}</span>
            <span class="faq-ic" aria-hidden="true"><svg viewBox="0 0 16 16" width="16" height="16"><path d="M3 6 8 11 13 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </summary>
          <div class="faq-a"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-head { text-align: center; margin-bottom: clamp(2rem, 1rem + 3vw, 3.5rem); }
  .faq-head .kicker { justify-content: center; }
  .faq-head h2 { font-size: var(--step-3); margin-top: 0.8rem; }

  .faq-list { display: flex; flex-direction: column; gap: 0.7rem; }
  .faq-item {
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius);
    overflow: hidden; transition: border-color var(--dur-fast), background var(--dur-fast);
  }
  .faq-item[open] { border-color: var(--primary-dim); background: var(--surface-2); }
  .faq-item summary {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.15rem 1.3rem; cursor: pointer; list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-q { font-family: var(--font-display); font-weight: 600; font-size: var(--step-1); letter-spacing: -0.01em; }
  .faq-ic { flex-shrink: 0; width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center; background: var(--surface-hi); color: var(--primary-hi); transition: transform var(--dur-fast) var(--ease-out-quart); }
  .faq-item[open] .faq-ic { transform: rotate(180deg); }
  .faq-a { padding: 0 1.3rem 1.25rem; }
  .faq-a p { color: var(--ink-2); line-height: 1.6; max-width: 64ch; }

  /* gentle open animation */
  html.has-motion .faq-item[open] .faq-a { animation: faqOpen 0.4s var(--ease-out-expo); }
  @keyframes faqOpen { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) { html.has-motion .faq-item[open] .faq-a { animation: none; } }
</style>
