---
// Social proof — brand logos drifting left→right + face testimonials right→left.
const brands = [
  { n: "Northpeak", i: "circle" },
  { n: "Lumen", i: "tri" },
  { n: "Brightline", i: "bolt" },
  { n: "Vellum", i: "diamond" },
  { n: "Strive", i: "rings" },
  { n: "Meridian", i: "hex" },
  { n: "Cloudbase", i: "square" },
  { n: "Apex Studio", i: "star" },
];
const testimonials = [
  { a: "a12", q: "It books calls while we sleep. We went from chasing DMs to just showing up to closes.", n: "Maya R.", r: "Founder, coaching studio" },
  { a: "a5",  q: "Replies in seconds, every time. Our show-rate jumped and we didn't hire a single rep.", n: "Daniel K.", r: "Head of Sales" },
  { a: "a33", q: "Honestly forgot it wasn't a human — it handled the price objection better than half my team.", n: "Priya S.", r: "Agency owner" },
  { a: "a47", q: "$40K closed entirely in chat. The thing pays for itself in the first week.", n: "Marcus L.", r: "Med-spa owner" },
  { a: "a26", q: "Set up in days, fully done-for-you. We just review the calendar now.", n: "Elena V.", r: "DTC brand" },
  { a: "a60", q: "Every channel, one brain. Warm leads never go cold on us anymore.", n: "Tom B.", r: "Real estate" },
];
---
<section class="proofstrip section" id="loved" aria-labelledby="ps-h">
  <div class="container ps-head">
    <p class="kicker reveal">Loved by operators</p>
    <h2 id="ps-h" class="reveal">The closer behind
      <span class="h-ic" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22"><path d="M12 2.5l2.7 5.9 6.3.7-4.7 4.3 1.3 6.3L12 16.8 6.1 19.7 7.4 13.4 2.7 9.1l6.3-.7z" fill="currentColor"/></svg></span>
      1,000+ booked calls.</h2>
  </div>

  <!-- brand logos: left → right -->
  <div class="marq logos" data-marquee aria-label="Brands we work with">
    <div class="marq-track marq-ltr">
      {[...brands, ...brands].map((b) => (
        <span class="logo-item">
          <span class="logo-mk">
            {b.i === "circle" && <svg viewBox="0 0 24 24" width="22" height="22"><circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="2.4"/></svg>}
            {b.i === "tri" && <svg viewBox="0 0 24 24" width="22" height="22"><path d="M12 4 21 19H3z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/></svg>}
            {b.i === "bolt" && <svg viewBox="0 0 24 24" width="22" height="22"><path d="M13 2 4 14h6l-1 8 9-12h-6l1-8Z" fill="currentColor"/></svg>}
            {b.i === "diamond" && <svg viewBox="0 0 24 24" width="22" height="22"><path d="M12 3 21 12 12 21 3 12z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/></svg>}
            {b.i === "rings" && <svg viewBox="0 0 24 24" width="22" height="22"><circle cx="9" cy="12" r="5.5" fill="none" stroke="currentColor" stroke-width="2.2"/><circle cx="15" cy="12" r="5.5" fill="none" stroke="currentColor" stroke-width="2.2"/></svg>}
            {b.i === "hex" && <svg viewBox="0 0 24 24" width="22" height="22"><path d="M7 4h10l4 8-4 8H7l-4-8z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/></svg>}
            {b.i === "square" && <svg viewBox="0 0 24 24" width="22" height="22"><rect x="4" y="4" width="16" height="16" rx="4" fill="none" stroke="currentColor" stroke-width="2.4"/></svg>}
            {b.i === "star" && <svg viewBox="0 0 24 24" width="22" height="22"><path d="M12 3l2.5 6 6.5.5-5 4.2 1.6 6.3L12 16.7 5.9 20l1.6-6.3-5-4.2 6.5-.5z" fill="currentColor"/></svg>}
          </span>
          <span class="logo-name">{b.n}</span>
        </span>
      ))}
    </div>
  </div>

  <!-- testimonials: right → left -->
  <div class="marq tms" data-marquee>
    <div class="marq-track marq-rtl">
      {[...testimonials, ...testimonials].map((t) => (
        <figure class="tcard">
          <div class="tstars" aria-hidden="true">★★★★★</div>
          <blockquote>“{t.q}”</blockquote>
          <figcaption class="twho">
            <img src={`/media/avatars/${t.a}.jpg`} alt="" width="44" height="44" loading="lazy" decoding="async" />
            <span><strong>{t.n}</strong><span class="trole">{t.r}</span></span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .proofstrip { overflow: clip; }
  .ps-head { text-align: center; margin-bottom: clamp(1.8rem, 1rem + 2vw, 3rem); }
  .ps-head h2 { font-size: var(--step-3); margin-top: 0.7rem; }

  /* shared marquee */
  .marq { -webkit-mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent); mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent); }
  .marq-track { display: flex; width: max-content; }
  .marq:hover .marq-track { animation-play-state: paused; }
  .marq-ltr { gap: clamp(2rem, 1rem + 3vw, 4rem); animation: ltr 34s linear infinite; }
  .marq-rtl { gap: 1.2rem; animation: rtl 48s linear infinite; }
  @keyframes ltr { from { transform: translateX(-50%); } to { transform: translateX(0); } }
  @keyframes rtl { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* logos */
  .logos { margin-bottom: clamp(1.6rem, 1rem + 2vw, 2.8rem); }
  .logo-item { display: inline-flex; align-items: center; gap: 0.6rem; color: var(--muted);
    font-family: var(--font-display); font-weight: 700; font-size: clamp(1.2rem, 1rem + 0.6vw, 1.6rem); letter-spacing: -0.01em;
    white-space: nowrap; transition: color var(--dur-fast); }
  .logo-item:hover { color: var(--ink); }
  .logo-mk { color: var(--primary-hi); display: inline-grid; place-items: center; }

  /* testimonials */
  .tcard {
    width: clamp(280px, 24vw, 360px); flex-shrink: 0; margin: 0;
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    border: 1px solid var(--line); border-radius: var(--radius-lg);
    padding: 1.3rem 1.4rem; display: flex; flex-direction: column; gap: 0.7rem;
  }
  .tstars { color: var(--accent); letter-spacing: 0.12em; font-size: 0.85rem; }
  .tcard blockquote { margin: 0; color: var(--ink); font-size: 0.98rem; line-height: 1.5; flex: 1; }
  .twho { display: flex; align-items: center; gap: 0.7rem; margin-top: 0.2rem; }
  .twho img { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; border: 1px solid var(--line); }
  .twho strong { display: block; font-family: var(--font-body); font-size: 0.92rem; }
  .trole { font-size: 0.8rem; color: var(--muted); }

  @media (prefers-reduced-motion: reduce) {
    .marq-ltr, .marq-rtl { animation: none; }
    .marq-rtl { flex-wrap: wrap; justify-content: center; }
  }
</style>
