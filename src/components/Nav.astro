---
import Logo from "./Logo.astro";
---
<header class="nav" data-nav>
  <div class="nav-inner container">
    <Logo />
    <nav class="nav-links" aria-label="Primary">
      <a href="#how">How it works</a>
      <a href="#capabilities">Capabilities</a>
      <a href="#channels">Channels</a>
      <a href="#pricing">Pricing</a>
    </nav>
    <div class="nav-cta">
      <a href="#pricing" class="btn btn-primary nav-btn" data-magnetic>Book a demo</a>
    </div>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" data-nav-toggle>
      <span></span><span></span>
    </button>
  </div>
  <nav class="nav-mobile" aria-label="Mobile" data-nav-mobile>
    <a href="#how">How it works</a>
    <a href="#capabilities">Capabilities</a>
    <a href="#channels">Channels</a>
    <a href="#pricing">Pricing</a>
    <a href="#pricing" class="btn btn-primary nav-mobile-cta">Book a demo</a>
  </nav>
</header>

<style>
  .nav {
    position: fixed; inset: 0 0 auto 0;
    z-index: var(--z-nav);
    transition: background var(--dur-fast) var(--ease-out-quart),
                border-color var(--dur-fast) var(--ease-out-quart),
                backdrop-filter var(--dur-fast);
    border-bottom: 1px solid transparent;
  }
  .nav[data-scrolled] {
    background: oklch(0.10 0.018 42 / 0.72);
    backdrop-filter: blur(14px) saturate(1.2);
    border-bottom-color: var(--line-soft);
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 72px;
    position: relative; z-index: 2;
  }
  .nav-links { display: flex; gap: 2rem; }
  .nav-links a {
    font-size: var(--step-0); color: var(--ink-2); font-weight: 500;
    position: relative; transition: color var(--dur-fast);
  }
  .nav-links a::after {
    content: ""; position: absolute; left: 0; bottom: -4px; height: 2px; width: 0;
    background: var(--primary); transition: width var(--dur-fast) var(--ease-out-quart);
  }
  .nav-links a:hover { color: var(--ink); }
  .nav-links a:hover::after { width: 100%; }

  .nav-cta { display: flex; align-items: center; gap: 1.1rem; }
  .nav-btn { padding: 0.6em 1.2em; font-size: var(--step--1); }

  .nav-toggle { display: none; width: 44px; height: 44px; flex-direction: column; gap: 5px; align-items: center; justify-content: center; position: relative; z-index: 3; }
  .nav-toggle span { width: 22px; height: 2px; background: var(--ink); border-radius: 2px; transition: transform var(--dur-fast) var(--ease-out-quart), opacity var(--dur-fast); }
  .nav-toggle[aria-expanded="true"] span:first-child { transform: translateY(3.5px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:last-child { transform: translateY(-3.5px) rotate(-45deg); }

  /* full-screen overlay menu */
  .nav-mobile {
    position: fixed; inset: 0; z-index: 1;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.4rem;
    padding: 5rem 1.5rem 3rem;
    background: oklch(0.07 0.014 42 / 0.97);
    backdrop-filter: blur(20px);
    opacity: 0; visibility: hidden; transform: translateY(-8px);
    transition: opacity 0.3s var(--ease-out-quart), transform 0.3s var(--ease-out-quart), visibility 0.3s;
  }
  .nav-mobile a {
    width: min(420px, 100%); text-align: center;
    padding: 1rem 0; font-size: 1.7rem; font-family: var(--font-display); font-weight: 700;
    color: var(--ink); letter-spacing: -0.01em;
  }
  .nav-mobile a:not(.btn) { border-bottom: 1px solid var(--line-soft); }
  .nav-mobile-cta { justify-content: center; color: var(--on-primary) !important; margin-top: 1.2rem; border: none !important; font-family: var(--font-body); font-size: 1.1rem; }
  .nav-mobile[data-open] { opacity: 1; visibility: visible; transform: none; }

  @media (max-width: 820px) {
    .nav-links, .nav-cta { display: none; }
    .nav-toggle { display: flex; }
  }
  @media (min-width: 821px) {
    .nav-mobile { display: none; }
  }
</style>
