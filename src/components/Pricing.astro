---
const plans = [
  {
    name: "Starter", price: "97", cadence: "/mo",
    tagline: "For solo coaches and operators closing in one inbox.",
    features: [
      "1 channel (Instagram or WhatsApp)",
      "Up to 150 conversations / month",
      "Instant replies + objection handling",
      "Books calls inside the chat",
      "2 automatic smart follow-ups",
      "Email support",
    ],
    cta: "Start free trial", featured: false,
  },
  {
    name: "Growth", price: "297", cadence: "/mo",
    tagline: "For businesses with leads coming in on every channel.",
    features: [
      "All 4 channels in one inbox",
      "Up to 600 conversations / month",
      "Comment-to-DM automation",
      "Contact memory + no-show reschedule",
      "Calendar + CRM integrations",
      "Priority support + onboarding call",
    ],
    cta: "Start free trial", featured: true,
  },
  {
    name: "Pro", price: "497", cadence: "/mo",
    tagline: "For high-volume and multi-location sales teams.",
    features: [
      "Everything in Growth, plus:",
      "Up to 1,500 conversations / month",
      "Outbound DM campaigns + sequences",
      "Voice, image, video & PDF understanding",
      "Advanced AI tuning + live web search",
      "Done-for-you setup + dedicated manager",
    ],
    cta: "Start free trial", featured: false,
  },
];
---
<section class="pricing section" id="pricing" aria-labelledby="pricing-h">
  <div class="container">
    <header class="pricing-head">
      <p class="eyebrow reveal">Start free. Pay when it works.</p>
      <h2 id="pricing-h" class="reveal">Try it for 7 days. Watch it book a call.</h2>
      <p class="pricing-sub reveal">No credit card to start. Connect your inbox, let the AI run live, and decide once you have seen it close. Most accounts book their first call inside the trial.</p>
      <p class="pricing-anchor reveal">A human appointment setter costs <strong>$2,000&ndash;$4,000 a month</strong>, works 8 hours a day, and quits. DMClosed starts at $97 and never clocks out.</p>
    </header>

    <div class="plans">
      {plans.map((p) => (
        <article class={`plan reveal ${p.featured ? "plan-featured" : ""}`}>
          {p.featured && <span class="plan-badge">Most popular</span>}
          <h3 class="plan-name">{p.name}</h3>
          <p class="plan-tagline">{p.tagline}</p>
          <div class="plan-price">
            <span class="plan-cur">$</span><span class="plan-amt">{p.price}</span><span class="plan-cad">{p.cadence}</span>
          </div>
          <a href="#" class={`btn ${p.featured ? "btn-primary" : "btn-ghost"} plan-cta`}>{p.cta}</a>
          <ul class="plan-feats">
            {p.features.map((f) => (
              <li><svg viewBox="0 0 16 16" width="15" height="15" aria-hidden="true"><path d="M3 8.5 6 11.5 13 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> {f}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="pricing-define reveal">
      <span class="define-ic" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="20" height="20"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M12 11v5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="7.6" r="1.2" fill="currentColor"/></svg>
      </span>
      <p>
        <strong>What counts as a conversation?</strong>
        One lead, handled start to finish, qualifying, answering questions, handling objections, and booking the call, no matter how many messages it takes. You are billed per lead the AI talks to, never per message. Need more in a busy month? Add a conversation pack anytime, no plan change required.
      </p>
    </div>

    <p class="pricing-foot reveal">Every plan includes a 7-day free trial &middot; cancel anytime &middot; no setup fees.</p>
  </div>
</section>

<style>
  .pricing-head { text-align: center; margin-bottom: clamp(2.5rem, 1rem + 4vw, 4rem); }
  .pricing-head h2 { font-size: var(--step-3); margin: 0.8rem 0 1rem; }
  .pricing-sub { color: var(--ink-2); font-size: var(--step-1); max-width: 54ch; margin-inline: auto; line-height: 1.55; }
  .pricing-anchor {
    margin: 1.4rem auto 0; max-width: 52ch; color: var(--muted); font-size: var(--step-0); line-height: 1.5;
    padding: 0.85rem 1.2rem; border: 1px solid var(--line-soft); border-radius: var(--radius-pill);
    background: var(--surface);
  }
  .pricing-anchor strong { color: var(--ink); font-weight: 600; }

  .plans { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; align-items: start; }
  @media (max-width: 880px) { .plans { grid-template-columns: 1fr; max-width: 440px; margin-inline: auto; } }
  .plan {
    position: relative;
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    border: 1px solid var(--line); border-radius: var(--radius-lg);
    padding: 2rem 1.7rem;
    transition: transform var(--dur-fast) var(--ease-out-quart), border-color var(--dur-fast);
  }
  .plan:hover { transform: translateY(-5px); }
  .plan-featured {
    border-color: var(--primary);
    box-shadow: 0 0 0 1px var(--primary), 0 30px 70px -30px var(--glow-indigo);
  }
  .plan-badge {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    background: var(--primary-strong); color: var(--on-primary);
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
    padding: 0.3rem 0.85rem; border-radius: var(--radius-pill); white-space: nowrap;
    box-shadow: 0 8px 20px -6px var(--glow-indigo);
  }
  .plan-name { font-size: var(--step-2); margin-bottom: 0.4rem; }
  .plan-tagline { color: var(--ink-2); font-size: 0.95rem; line-height: 1.45; min-height: 2.8em; margin-bottom: 1.2rem; }
  .plan-price { display: flex; align-items: baseline; gap: 0.15rem; margin-bottom: 1.4rem; }
  .plan-cur { font-family: var(--font-display); font-size: var(--step-2); font-weight: 700; color: var(--ink-2); }
  .plan-amt { font-family: var(--font-display); font-size: var(--step-4); font-weight: 800; line-height: 1; }
  .plan-cad { color: var(--muted); font-size: var(--step-0); }
  .plan-cta { width: 100%; justify-content: center; margin-bottom: 1.6rem; }
  .plan-feats { display: flex; flex-direction: column; gap: 0.7rem; }
  .plan-feats li { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.95rem; color: var(--ink-2); line-height: 1.4; }
  .plan-feats li:first-child { color: var(--ink); font-weight: 600; }
  .plan-feats svg { color: var(--accent); flex-shrink: 0; margin-top: 0.25em; }

  .pricing-define {
    display: flex; align-items: flex-start; gap: 0.85rem;
    max-width: 64ch; margin: 2.2rem auto 0;
    padding: 1.1rem 1.3rem;
    background: var(--surface); border: 1px solid var(--line-soft);
    border-radius: var(--radius);
  }
  .define-ic { flex-shrink: 0; color: var(--accent); margin-top: 0.1rem; }
  .pricing-define p { color: var(--ink-2); font-size: 0.95rem; line-height: 1.55; }
  .pricing-define strong { color: var(--ink); font-weight: 600; }

  .pricing-foot { text-align: center; color: var(--muted); font-size: var(--step--1); margin-top: 1.5rem; }
</style>
