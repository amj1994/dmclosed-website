---
import Robot from "./Robot.astro";
---
<section class="cta section" aria-labelledby="cta-h">
  <div class="cta-glow" aria-hidden="true"></div>
  <span class="cta-robot"><Robot variant="wave" /></span>
  <div class="container-narrow cta-inner">
    <p class="kicker reveal">Your DMs are open right now</p>
    <h2 id="cta-h" class="cta-h reveal">There are buyers in your inbox<br />going cold as you read this.</h2>
    <p class="cta-sub reveal">Put a closer in there this week. Book a 20-minute demo and we'll show you exactly how DMClosed turns the conversations your team is missing into calls on your calendar.</p>
    <div class="cta-actions reveal">
      <a href="#pricing" class="btn btn-primary btn-lg btn-arrow" data-magnetic>
        Book a demo
        <svg viewBox="0 0 24 24" width="18" height="18"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#how" class="btn btn-ghost btn-lg">See how it works</a>
    </div>
    <p class="cta-fine reveal">Done&#8209;for&#8209;you setup · live in days · month&#8209;to&#8209;month</p>
  </div>
</section>

<style>
  .cta { position: relative; overflow: clip; text-align: center; }
  .cta .kicker { justify-content: center; }
  .cta-glow {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background:
      radial-gradient(50% 60% at 50% 50%, var(--glow-ember), transparent 70%),
      radial-gradient(40% 40% at 20% 80%, var(--glow-amber), transparent 70%);
    opacity: 0.55;
    animation: ctaPulse 9s ease-in-out infinite;
  }
  @keyframes ctaPulse { 0%,100%{opacity:0.45; transform:scale(1)} 50%{opacity:0.65; transform:scale(1.05)} }
  .cta-inner { position: relative; z-index: 1; }
  .cta-robot { position: absolute; top: 12%; right: 6%; width: 116px; height: 145px; z-index: 1; }
  @media (max-width: 860px) { .cta-robot { display: none; } }
  .cta-h { font-size: var(--step-4); margin: 0.9rem 0 1.3rem; }
  .cta-sub { font-size: var(--step-1); color: var(--ink-2); max-width: 54ch; margin: 0 auto 2rem; line-height: 1.55; }
  .cta-actions { display: flex; flex-wrap: wrap; gap: 0.9rem; justify-content: center; margin-bottom: 1.4rem; }
  .cta-fine { color: var(--muted); font-size: var(--step--1); }
  @media (prefers-reduced-motion: reduce) { .cta-glow { animation: none; } }
</style>
